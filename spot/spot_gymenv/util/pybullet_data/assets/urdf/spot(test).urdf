    <inertial><origin xyz="0 0 -0.06"/><mass value="0.08"/><inertia ixx="0.00007" ixy="0" ixz="0" iyy="0.00007" iyz="0" izz="0.00001"/></inertial>
  </link>

  <joint name="motor_front_right_lower_leg" type="revolute">
