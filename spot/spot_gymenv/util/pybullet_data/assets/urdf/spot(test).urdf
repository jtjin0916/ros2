<?xml version="1.0" encoding="utf-8"?>
<robot name="spot_box_only">

  <material name="orange">
    <color rgba="1.0 0.5 0.0 1"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  <material name="grey">
    <color rgba="0.6 0.6 0.6 1"/>
  </material>

  <!-- =========================
       BASE
       ========================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="stl/mainbody.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
      <origin rpy="0 0 3.14159" xyz="0.045 0.060 -0.015"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.11 0.07"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.0025" ixy="0" ixz="0"
               iyy="0.0015" iyz="0"
               izz="0.0026"/>
    </inertial>
  </link>

  <!-- =========================
       FRONT LEFT
       ========================= -->
  <link name="front_left_hip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.03"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.00014" ixy="0" ixz="0"
               iyy="0.00011" iyz="0"
               izz="0.00011"/>
    </inertial>
  </link>

  <joint name="motor_front_left_hip" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_hip"/>
    <origin xyz="0.096 0.042 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="100.0" lower="-1.04" upper="1.04" velocity="0.7"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="front_left_upper_leg">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.10"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.00014" ixy="0" ixz="0"
               iyy="0.00014" iyz="0"
               izz="0.00003"/>
    </inertial>
  </link>

  <joint name="motor_front_left_upper_leg" type="revolute">
    <parent link="front_left_hip"/>
    <child link="front_left_upper_leg"/>
    <origin xyz="0.0 0.045 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="-1.571" upper="2.59" velocity="0.7"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="front_left_lower_leg">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.12"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00007" ixy="0" ixz="0"
               iyy="0.00007" iyz="0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="motor_front_left_lower_leg" type="revolute">
    <parent link="front_left_upper_leg"/>
    <child link="front_left_lower_leg"/>
    <origin xyz="0.0 0.0 -0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="-2.9" upper="1.671" velocity="0.7"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="front_left_foot">
    <visual>
      <geometry>
        <mesh filename="stl/foot.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 -0.40010 0" xyz="0 -0.01 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="stl/foot.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 -0.40010 0" xyz="0 -0.01 0"/>
      <contact_coefficients mu="100.0"/>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100"/>
    </inertial>
  </link>

  <joint name="front_left_leg_foot" type="fixed">
    <parent link="front_left_lower_leg"/>
    <child link="front_left_foot"/>
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       FRONT RIGHT
       ========================= -->
  <link name="front_right_hip">
    <visual><origin xyz="0 0 0"/><geometry><box size="0.04 0.03 0.03"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 0"/><geometry><box size="0.04 0.03 0.03"/></geometry></collision>
    <inertial><origin xyz="0 0 0"/><mass value="0.10"/><inertia ixx="0.00014" ixy="0" ixz="0" iyy="0.00011" iyz="0" izz="0.00011"/></inertial>
  </link>

  <joint name="motor_front_right_hip" type="revolute">
    <parent link="base_link"/>
